# Copy this file to .env and fill in your DeepSeek API key.
# If DEEPSEEK_API_KEY is not set, the app runs in mock mode:
# tokens still appear as stars but cluster randomly (not semantically).

DEEPSEEK_API_KEY=sk-...

# Set to true to force mock embeddings even if a key is provided.
FORCE_MOCK=false

# Port for the Express + WebSocket server (default: 3001)
PORT=3001
